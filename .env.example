# tech-news-synth — example env file
# Copy to .env and fill in real values. NEVER commit .env.

# --- Runtime knobs ---
INTERVAL_HOURS=2
PAUSED=0
DRY_RUN=0
LOG_DIR=/data/logs
PAUSED_MARKER_PATH=/data/paused

# --- Anthropic (Claude Haiku 4.5) ---
ANTHROPIC_API_KEY=sk-ant-replace-me

# --- X OAuth 1.0a User Context (4 secrets for @ByteRelevant) ---
X_CONSUMER_KEY=replace-me
X_CONSUMER_SECRET=replace-me
X_ACCESS_TOKEN=replace-me
X_ACCESS_TOKEN_SECRET=replace-me

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tech_news_synth
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-me
