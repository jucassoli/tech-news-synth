# tech-news-synth — example env file
# Copy to .env and fill in real values. NEVER commit .env.

# --- Runtime knobs ---
INTERVAL_HOURS=2
PAUSED=0
DRY_RUN=0
LOG_DIR=/data/logs
PAUSED_MARKER_PATH=/data/paused

# --- Phase 4 ingest ---
SOURCES_CONFIG_PATH=/app/config/sources.yaml
MAX_CONSECUTIVE_FAILURES=20

# --- Phase 5 clustering (defaults shown; uncomment to override) ---
# CLUSTER_WINDOW_HOURS=6
# CLUSTER_DISTANCE_THRESHOLD=0.35
# ANTI_REPEAT_COSINE_THRESHOLD=0.5
# ANTI_REPEAT_WINDOW_HOURS=48

# --- Phase 6 synthesis (defaults shown; uncomment to override) ---
# SYNTHESIS_MAX_TOKENS=150
# SYNTHESIS_CHAR_BUDGET=225
# SYNTHESIS_MAX_RETRIES=2
# HASHTAG_BUDGET_CHARS=30
# HASHTAGS_CONFIG_PATH=/app/config/hashtags.yaml

# --- Phase 7 publish (defaults shown; uncomment to override) ---
# MAX_POSTS_PER_DAY=12
# MAX_MONTHLY_COST_USD=30.00
# PUBLISH_STALE_PENDING_MINUTES=5
# X_API_TIMEOUT_SEC=30

# --- Anthropic (Claude Haiku 4.5) ---
ANTHROPIC_API_KEY=sk-ant-replace-me

# --- X OAuth 1.0a User Context (4 secrets for @ByteRelevant) ---
X_CONSUMER_KEY=replace-me
X_CONSUMER_SECRET=replace-me
X_ACCESS_TOKEN=replace-me
X_ACCESS_TOKEN_SECRET=replace-me

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tech_news_synth
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-me

# Phase 2 (optional): override test DB DSN. Default: <DATABASE_URL> with db suffixed _test.
# TEST_DATABASE_URL=postgresql+psycopg://app:REPLACE_ME@postgres:5432/tech_news_synth_test
